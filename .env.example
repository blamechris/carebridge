# Database
DATABASE_URL=postgresql://carebridge:carebridge_dev@localhost:5432/carebridge

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=  # Set in production with requirepass

# API
API_PORT=4000
API_HOST=0.0.0.0

# CORS — set to specific origin(s) in production, never leave as "true"
# CORS_ORIGIN=https://carebridge.example.com

# Claude API (for AI oversight engine)
# IMPORTANT: A signed BAA with Anthropic is required before using this feature
# with real PHI. See: https://anthropic.com/enterprise
ANTHROPIC_API_KEY=sk-ant-...

# Auth
SESSION_SECRET=change-me-in-production

# Environment
NODE_ENV=development

# Dev auth bypass — ONLY set this in local development, NEVER in any environment
# that handles real PHI. Requires explicit opt-in separate from NODE_ENV.
# CAREBRIDGE_DEV_AUTH=true
