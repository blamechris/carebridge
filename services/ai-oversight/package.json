{
  "name": "@carebridge/ai-oversight",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@carebridge/logger": "workspace:*",
    "@carebridge/redis-config": "workspace:*",
    "@carebridge/shared-types": "workspace:*",
    "@carebridge/notifications": "workspace:*",
    "@carebridge/phi-sanitizer": "workspace:*",
    "@carebridge/validators": "workspace:*",
    "@carebridge/db-schema": "workspace:*",
    "@carebridge/medical-logic": "workspace:*",
    "@carebridge/ai-prompts": "workspace:*",
    "@anthropic-ai/sdk": "^0.39.0",
    "bullmq": "^5.30.0",
    "drizzle-orm": "^0.38.0",
    "@trpc/server": "^11.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "vitest": "^3.0.0"
  }
}
